# ShieldSentinel AI — Environment Variables Template
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to git.

# Zhipu AI API Key (primary LLM — GLM-4v-plus)
# Get yours at: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI API Key (fallback LLM — gpt-4o-mini)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
